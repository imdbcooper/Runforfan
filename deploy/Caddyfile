{$RUNFORFAN_DOMAIN:run.slavx.ru} {
	encode zstd gzip

	handle /api/* {
		reverse_proxy 127.0.0.1:{$RUNFORFAN_BACKEND_PORT:18081}
	}

	handle /health {
		reverse_proxy 127.0.0.1:{$RUNFORFAN_BACKEND_PORT:18081}
	}

	handle /admin* {
		redir * /app/ 301
	}

	handle /app* {
		reverse_proxy 127.0.0.1:{$RUNFORFAN_FRONTEND_PORT:18080}
	}

	handle {
		redir * /app/ 302
	}
}
